# ─── Переменные окружения для продакшна ─────────────────────────────────────
# Скопировать этот файл в /opt/crm/.env и заполнить значения.

# Секрет для подписи JWT-токенов. ОБЯЗАТЕЛЬНО сгенерировать свой!
#   Команда: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_LONG_RANDOM_STRING

# Путь к SQLite-базе. Хранится в /opt/crm/data/, чтобы пережить переустановку.
CRM_B2B_DATABASE_URL=sqlite:////opt/crm/data/prod.db

# Доменное имя CRM (используется в логах и для CORS)
CRM_DOMAIN=crm.rutestin.com

# Разрешённые origin для CORS — через запятую, без пробелов
CRM_ALLOWED_ORIGINS=https://crm.rutestin.com

# Путь к шаблону DOCX для генерации КП (опционально)
QUOTE_DOCX_TEMPLATE_PATH=/opt/crm/backend/templates/quote_template.docx
